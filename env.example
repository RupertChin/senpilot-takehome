# .env.example — copy to .env and fill in. NEVER commit .env.
# Grouped by when you need it: build/test locally now vs. fill in at deploy time.

# ── Core ─────────────────────────────────────────────────────────────────────
ENV=local                       # local | prod  (auto-detects prod on Cloud Run via K_SERVICE)
QUEUE_MODE=inline               # inline | tasks  (inline = no Cloud Tasks; use for local + the first deploy)

# ── Needed to build & test locally ───────────────────────────────────────────
ANTHROPIC_API_KEY=              # classify / extract / summarize
AGENTMAIL_API_KEY=              # the agent's inbox API key
AGENTMAIL_INBOX=                # the agent's address, e.g. agent@agentmail.to
AGENTMAIL_WEBHOOK_SECRET=       # for inbound webhook signature verification (needed when wiring real inbound)
SUPABASE_URL=                   # state store (idempotency / jobs / threads)
SUPABASE_KEY=                   # service-role key (server-side only)

# ── Models & tunables (defaults are fine) ────────────────────────────────────
CLASSIFY_MODEL=claude-haiku-4-5
EXTRACT_MODEL=claude-sonnet-4-6
SUMMARY_MODEL=claude-sonnet-4-6
MAX_DOCUMENTS=10                # hard cap of documents (rows) per request
ATTACH_THRESHOLD_BYTES=18000000 # raw zip <= this -> attach; above -> GCS link (18MB leaves room for base64 inflation under a 25MB limit)
SIGNED_URL_TTL_HOURS=72         # TTL of the GCS link used for oversized zips
POLITE_DELAY_S=0.6              # gap between sequential downloads (politeness toward the gov site)

# ── Fill in at deploy time (not needed for local build) ──────────────────────
GCP_PROJECT=                    # required in prod
GCS_BUCKET=                     # only used when a zip exceeds ATTACH_THRESHOLD_BYTES
TASKS_QUEUE=                    # Cloud Tasks queue id (only when QUEUE_MODE=tasks)
TASKS_LOCATION=us-central1
PROCESS_URL=                    # absolute URL of /process (Cloud Tasks target)
TASKS_INVOKER_SA=               # service account email for OIDC on the task
SENTRY_DSN=                     # empty disables Sentry
